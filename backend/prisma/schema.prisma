generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  FREELANCER
  CUSTOMER
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  role      Role     @default(FREELANCER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  freelancerProfile FreelancerProfile?
  customerProfile   CustomerProfile?
}

model FreelancerProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio          String?
  hourlyRate   Float?
  portfolioUrl String?
  resumeUrl    String?
  skills       Skill[]  @relation("FreelancerSkills")
  
  assignedJobs Job[]    @relation("AssignedFreelancer")
  reviews      Review[] @relation("ReceivedReviews")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CustomerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   String?
  
  jobs      Job[]    @relation("CustomerJobs")
  reviews   Review[] @relation("GivenReviews")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id             String          @id @default(uuid())
  
  customerId     String
  customer       CustomerProfile @relation("CustomerJobs", fields: [customerId], references: [id], onDelete: Cascade)
  
  freelancerId   String?
  freelancer     FreelancerProfile? @relation("AssignedFreelancer", fields: [freelancerId], references: [id])

  title          String
  description    String
  category       String?
  experienceLevel String?
  duration       String?
  budget         Float?
  status         JobStatus       @default(OPEN)

  requiredSkills Skill[]         @relation("JobSkills")
  review         Review?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Review {
  id           String   @id @default(uuid())
  score        Int
  comment      String?
  
  jobId        String   @unique
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  reviewerId   String
  reviewer     CustomerProfile @relation("GivenReviews", fields: [reviewerId], references: [id])
  
  revieweeId   String
  reviewee     FreelancerProfile @relation("ReceivedReviews", fields: [revieweeId], references: [id])
  
  createdAt    DateTime @default(now())
}

model Skill {
  id          String              @id @default(uuid())
  name        String              @unique
  freelancers FreelancerProfile[] @relation("FreelancerSkills")
  jobs        Job[]               @relation("JobSkills")
}
