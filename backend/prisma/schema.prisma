generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  FREELANCER
  CUSTOMER
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  role      Role     @default(FREELANCER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  freelancerProfile FreelancerProfile?
  customerProfile   CustomerProfile?
  notifications     Notification[]
  messages          Message[]
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
}

model FreelancerProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio          String?
  hourlyRate   Float?
  portfolioUrl String?
  resumeUrl    String?
  skills       Skill[]  @relation("FreelancerSkills")
  
  assignedJobs Job[]    @relation("AssignedFreelancer")
  reviews      Review[] @relation("ReceivedReviews")
  applications Application[] @relation("FreelancerApplications")
  conversations Conversation[] @relation("FreelancerConversations")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CustomerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   String?
  
  jobs      Job[]    @relation("CustomerJobs")
  reviews   Review[] @relation("GivenReviews")
  conversations Conversation[] @relation("CustomerConversations")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id             String          @id @default(uuid())
  
  customerId     String
  customer       CustomerProfile @relation("CustomerJobs", fields: [customerId], references: [id], onDelete: Cascade)
  
  freelancerId   String?
  freelancer     FreelancerProfile? @relation("AssignedFreelancer", fields: [freelancerId], references: [id])

  title          String
  description    String
  category       String?
  experienceLevel String?
  duration       String?
  budget         Float?
  status         JobStatus       @default(OPEN)

  requiredSkills Skill[]         @relation("JobSkills")
  review         Review?
  applications   Application[]   @relation("JobApplications")

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status])
  @@index([customerId])
  @@index([freelancerId])
  @@index([category])
  @@index([createdAt])
}

model Review {
  id           String   @id @default(uuid())
  score        Int
  comment      String?
  
  jobId        String   @unique
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  reviewerId   String
  reviewer     CustomerProfile @relation("GivenReviews", fields: [reviewerId], references: [id])
  
  revieweeId   String
  reviewee     FreelancerProfile @relation("ReceivedReviews", fields: [revieweeId], references: [id])
  
  createdAt    DateTime @default(now())
}

model Skill {
  id          String              @id @default(uuid())
  name        String              @unique
  freelancers FreelancerProfile[] @relation("FreelancerSkills")
  jobs        Job[]               @relation("JobSkills")
}

model Application {
  id           String            @id @default(uuid())
  
  jobId        String
  job          Job               @relation("JobApplications", fields: [jobId], references: [id], onDelete: Cascade)
  
  freelancerId String
  freelancer   FreelancerProfile @relation("FreelancerApplications", fields: [freelancerId], references: [id], onDelete: Cascade)
  
  coverLetter  String
  status       String            @default("PENDING")
  
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  
  @@unique([jobId, freelancerId])
  @@index([status])
  @@index([jobId])
  @@index([freelancerId])
}

model Conversation {
  id           String   @id @default(uuid())
  customerId   String
  freelancerId String
  isBlocked    Boolean  @default(false)
  blockedById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer     CustomerProfile   @relation("CustomerConversations", fields: [customerId], references: [id], onDelete: Cascade)
  freelancer   FreelancerProfile @relation("FreelancerConversations", fields: [freelancerId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@unique([customerId, freelancerId])
  @@index([customerId])
  @@index([freelancerId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  @@index([conversationId])
}
